# Shared
FLASK_DEBUG=1
FFMPEG_DIR=C:\Users\Administrator\AppData\Local\Microsoft\WinGet\Links

# TTS service bind address
TTS_HOST=0.0.0.0
TTS_PORT=5000

# Optional public URL override for the web app.
# Leave empty when the browser should use the current host automatically.
TTS_PUBLIC_BASE_URL=

# STT service bind address
STT_HOST=0.0.0.0
STT_PORT=5001

# Optional public STT override.
# If empty, the frontend uses the current hostname plus STT_PORT.
STT_PUBLIC_BASE_URL=
STT_PUBLIC_HOST=
STT_PUBLIC_SCHEME=http

# Whisper
WHISPER_MODEL=small
WHISPER_LANG=en

# MCP wrapper target URLs
MCP_TTS_BASE_URL=http://127.0.0.1:5000
MCP_STT_BASE_URL=http://127.0.0.1:5001
